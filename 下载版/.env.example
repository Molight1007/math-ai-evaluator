# ============================================
# 数学智能体评测器 - API 配置文件
# ============================================
# 复制此文件为 .env 并填入你的 API Key
#   cp .env.example .env
#
# API Key 获取方式见 README.md

# ---- Intern-S1（书生浦语）- 推理模型 ----
# 获取地址: https://intern-ai.org.cn
INTERN_S1_API_KEY=your_intern_s1_api_key_here
INTERN_S1_BASE_URL=https://internlm-chat.intern-ai.org.cn/puyu/api/v1
INTERN_S1_MODEL=internlm3-latest

# ---- DeepSeek - 评判模型 ----
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---- 通用设置 ----
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
