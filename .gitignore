# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# 虚拟环境
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# CodeBuddy
.codebuddy/
.workbuddy/

# 敏感配置（含 API Key）
.env

# 测试结果（运行时生成）
测试结果/测试结果展示/
测试结果/原始输出和推理过程/
测试结果/原始问题/
测试结果/测试lean文件/

# 大文件 / 资料（非源码，体积大且可重新获取）
*.pdf
*.pptx
*.docx
*.rar
*.zip
*.zst                    # 大型压缩包（如 lean4 工具链）

# Lean 工具链（约 1.2GB，含二进制与编译产物，由 lean-toolchain 自动下载）
lean4-toolchain/

# Lean 编译产物与依赖（由 lake 自动拉取/生成）
*.olean
*.ilean
*.ir
*.private
*.server
.lake/
lake-packages/

# 运行时生成的题库数据库（SQLite）
*.db
*.db-shm
*.db-wal

# 运行/构建临时文件
*.tmp
*.log
~$*                      # Word 临时锁文件
build_pid.txt
*_done.txt
__pycache__/
